function calculerFrites(data, caTotal) {
  const stockMatinKg = getStockFritesMatin(data);
  const stockSoirKg = calculerStockFritesKg(data);
  const livraisonKg = n(data.fritesColis) * FRITES_KG_PAR_CARTON;

  const consoKg = stockMatinKg + livraisonKg - stockSoirKg;
  const consoEuro = consoKg * PRIX_KG_FRITES;
  const consoPctCA = caTotal > 0 ? consoEuro / caTotal : 0;

  const ecartPct = TAUX_THEORIQUE_FRITES - consoPctCA;
  const ecartKg = caTotal > 0 ? (ecartPct * caTotal) / PRIX_KG_FRITES : 0;

  let statut = "Conforme";

  if (ecartPct > 0) {
    statut = "Sous-consommation";
  } else if (ecartPct < 0) {
    statut = "Surconsommation";
  }

  return {
    stockMatinKg,
    livraisonKg,
    stockSoirKg,
    consoKg,
    consoEuro,
    consoPctCA,
    objectifPctCA: TAUX_THEORIQUE_FRITES,
    ecartPct,
    ecartKg,
    statut
  };
}

