    const data = JSON.parse(e.postData.contents);
    const service = normalize(data.service);

    creerOngletsPrevisionnelsSiBesoin();
    enregistrerDansSheet(data);

    if (!service.includes("matin")) {
      envoyerTelegram(data);
    }

    return jsonResponse({
      success: true,
      message: service.includes("matin")
        ? "Stock matin enregistré"
        : "Reporting enregistré et envoyé Telegram"
    });

  } catch (error) {
    return jsonResponse({
      success: false,
      message: error.message
    });
  }
}

