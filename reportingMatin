function calculerStockFritesKg(data) {
  return (
    n(data.fritesCarton) * FRITES_KG_PAR_CARTON +
    n(data.fritesSachet) * FRITES_KG_PAR_SACHET +
    n(data.fritesKg)
  );
}

function getStockFritesMatin(data) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = ss.getSheetByName(SHEET_NAME);

  if (!sheet || sheet.getLastRow() < 2) return 0;

  const rows = sheet.getDataRange().getValues();
  const headers = rows[0];

  const iDate = headers.indexOf("Date reporting");
  const iRestaurant = headers.indexOf("Restaurant");
  const iService = headers.indexOf("Service");
  const iStock = headers.indexOf("Stock Frites Kg");

  if (iDate === -1 || iRestaurant === -1 || iService === -1 || iStock === -1) {
    return 0;
  }

  const restaurant = normalize(data.restaurant);
  const dateReporting = formatDateKey(data.dateReporting);

  for (let i = rows.length - 1; i >= 1; i--) {
    if (
      formatDateKey(rows[i][iDate]) === dateReporting &&
      normalize(rows[i][iRestaurant]) === restaurant &&
      normalize(rows[i][iService]).includes("matin")
    ) {
      return n(rows[i][iStock]);
    }
  }

  return 0;
}

