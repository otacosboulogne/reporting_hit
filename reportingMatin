function genererAlertes(data, prev, caTotal, pertes, ticketMoyen, frites) {
  const alertes = [];

  if (prev.caTotalPrevu > 0 && caTotal < prev.caTotalPrevu) {
    alertes.push("⚠️ CA inférieur au prévisionnel");
  }

  if (prev.caTotalPrevu > 0 && pctEcart(caTotal, prev.caTotalPrevu) <= -10) {
    alertes.push("🚨 CA inférieur de plus de 10 % au prévisionnel");
  }

  if (prev.pertesPrevues > 0 && pertes > prev.pertesPrevues) {
    alertes.push("🚨 Pertes supérieures au prévisionnel");
  }

  if (caTotal > 0 && pertes / caTotal > 0.03) {
    alertes.push("🚨 Taux de pertes supérieur à 3 % du CA");
  }

  if (frites && frites.statut === "Surconsommation") {
    alertes.push("🚨 Surconsommation frites");
  }

  if (n(data.ecartCaisse) !== 0) {
    alertes.push("⚠️ Écart caisse à contrôler");
  }

  if (ticketMoyen > 0 && ticketMoyen < 10) {
    alertes.push("⚠️ Ticket moyen faible");
  }

  return alertes.length ? alertes.join("\n") : "✅ Aucun point critique détecté";
}

function creerOngletsPrevisionnelsSiBesoin() {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);

  RESTAURANTS_PREVISIONNEL.forEach(function(restaurant) {
    const sheetName = "Prévisionnel " + restaurant;
    let sheet = ss.getSheetByName(sheetName);

    if (!sheet) sheet = ss.insertSheet(sheetName);
    if (sheet.getLastRow() > 0) return;

    sheet.appendRow([
      "Date",
      "CA Comptoir",
      "CA Uber",
      "CA Deliveroo",
      "CA C&C",
      "CA Total",
      "Masse Salariale",
      "Pertes"
    ]);

    const startDate = new Date(2026, 0, 1);
    const endDate = new Date(2026, 11, 31);
    const rows = [];

    for (let date = new Date(startDate); date <= endDate; date.setDate(date.getDate() + 1)) {
      rows.push([new Date(date), "", "", "", "", "", "", ""]);
    }

    sheet.getRange(2, 1, rows.length, 8).setValues(rows);
    sheet.getRange("A:A").setNumberFormat("dddd d mmmm yyyy");
    sheet.getRange("B:H").setNumberFormat("#,##0 €");
    sheet.getRange(1, 1, 1, 8).setFontWeight("bold");
    sheet.setFrozenRows(1);
    sheet.autoResizeColumns(1, 8);
  });
}

function getPrevisionnel(data) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const restaurant = trouverNomRestaurantPrevisionnel(data.restaurant);
  const sheet = ss.getSheetByName("Prévisionnel " + restaurant);

  if (!sheet) return emptyPrevisionnel();

  const rows = sheet.getDataRange().getValues();
  const dateReporting = formatDateKey(data.dateReporting);

  for (let i = 1; i < rows.length; i++) {
    if (formatDateKey(rows[i][0]) === dateReporting) {
      return {
        caRestaurantPrevu: n(rows[i][1]),
        caUberPrevu: n(rows[i][2]),
        caDeliverooPrevu: n(rows[i][3]),
        caCCPrevu: n(rows[i][4]),
        caTotalPrevu: n(rows[i][5]),
        masseSalarialePrevue: n(rows[i][6]),
        pertesPrevues: n(rows[i][7])
      };
    }
  }

  return emptyPrevisionnel();
}

function trouverNomRestaurantPrevisionnel(value) {
  const restaurant = normalize(value);
  if (restaurant.includes("boulogne")) return "Boulogne";
  if (restaurant.includes("arment")) return "Armentières";
  return value || "";
}

function emptyPrevisionnel() {
  return {
    caRestaurantPrevu: 0,
    caUberPrevu: 0,
    caDeliverooPrevu: 0,
    caCCPrevu: 0,
    caTotalPrevu: 0,
    masseSalarialePrevue: 0,
    pertesPrevues: 0
  };
}

function n(value) {
  if (value === "" || value === null || value === undefined) return 0;
  return Number(String(value).replace(",", ".")) || 0;
}

function ratio(value, total) {
  total = n(total);
  return total > 0 ? n(value) / total : 0;
}

function normalize(value) {
  return String(value || "")
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "");
}

function formatDateKey(value) {
  if (!value) return "";
  const date = value instanceof Date ? value : new Date(value);
  return Utilities.formatDate(date, Session.getScriptTimeZone(), "yyyy-MM-dd");
}

function euro(value) {
  return n(value).toFixed(2) + " €";
}

function formatPct(value) {
  return (n(value) * 100).toFixed(2) + " %";
}

function pctEcart(reel, prevu) {
  reel = n(reel);
  prevu = n(prevu);
  if (prevu === 0) return 0;
  return ((reel - prevu) / prevu) * 100;
}

function ecartPct(reel, prevu) {
  const pct = pctEcart(reel, prevu);
  return (pct >= 0 ? "+" : "") + pct.toFixed(2) + " %";
}

function ecartEuro(reel, prevu) {
  const ecart = n(reel) - n(prevu);
  return (ecart >= 0 ? "+" : "") + ecart.toFixed(2) + " €";
}

function statutObjectif(reel, prevu) {
  if (prevu === 0) return "ℹ️ Aucun prévisionnel renseigné";
  return reel >= prevu ? "✅ Objectif CA atteint" : "⚠️ Objectif CA non atteint";
}

function statutPertes(reel, prevu) {
  if (prevu === 0) return "ℹ️ Aucun prévisionnel pertes renseigné";
  return reel <= prevu ? "✅ Pertes maîtrisées" : "🚨 Pertes supérieures au prévisionnel";
}

function jsonResponse(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}

function doGet() {
  creerOngletsPrevisionnelsSiBesoin();

  return jsonResponse({
    success: true,
    message: "Web App Reporting O'TACOS active"
  });
}
